{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node ./scripts/preinstall-check.mjs",
    "dev:api": "node ./scripts/with-env.mjs pnpm --filter @workspace/api-server run dev",
    "dev:mobile": "pnpm --filter @workspace/mobile run dev",
    "db:push": "pnpm run db:push:postgres",
    "db:push:postgres": "node ./scripts/with-env.mjs pnpm --filter @workspace/db run push:postgres",
    "db:push:neon": "pnpm run db:push:postgres",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./apps/**\" --filter \"!./apps/mockup-sandbox\" --filter \"./scripts\" --if-present run typecheck",
    "lint": "eslint ."
  },
  "private": true,
  "type": "module",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.3"
  },
  "dependencies": {
    "@replit/connectors-sdk": "^0.4.1"
  }
}
