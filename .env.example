# Copie ce fichier en `.env`, puis remplace DATABASE_URL par l'URL Neon.
# Neon donne une URL PostgreSQL du style :
# postgresql://USER:PASSWORD@ep-xxxxx.region.aws.neon.tech/DB?sslmode=require

NODE_ENV=development
PORT=8080
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
JWT_SECRET=change-me-with-a-long-random-secret-min-16-chars
